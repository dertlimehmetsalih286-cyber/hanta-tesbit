{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepOnInactivity": false,
    "restartPolicyType": "ON_FAILURE",
    "buildCommand": "yarn build",
    "startCommand": "npx serve -s dist -l 4173",
    "port": 4173
  }
}
